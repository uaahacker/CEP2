# ── AWS Credentials ──────────────────────────────────────────────────────────
# Required only if you want to connect to real AWS Cost Explorer.
# Leave blank to use Demo Mode with synthetic data.
# IMPORTANT: Never commit a filled .env file to Git.
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ── App Settings ─────────────────────────────────────────────────────────────
# Optional: path to the SQLite user database (defaults to users.db in /app)
AUTH_DB_PATH=users.db

# ── Streamlit Server ─────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
